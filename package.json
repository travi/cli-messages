{
  "name": "@travi/cli-messages",
  "description": "status messaging for output of CLI applications",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "travi/cli-messages",
  "bugs": "https://github.com/travi/cli-messages/issues",
  "homepage": "https://npm.im/@travi/cli-messages",
  "main": "lib/index.cjs.js",
  "module": "lib/index.es.js",
  "sideEffects": false,
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "test:unit": "cross-env NODE_ENV=test c8 run-s test:unit:base",
    "test:unit:base": "DEBUG=any mocha --recursive test/unit",
    "lint:js": "eslint . --cache",
    "lint:md": "remark . --frail",
    "lint:sensitive": "ban",
    "clean": "rimraf ./lib",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "watch": "run-s 'build:js -- --watch'",
    "prepack": "run-s build",
    "prepare": "husky install",
    "lint:publish": "publint",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint"
  },
  "files": [
    "lib/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.16.0+sha512.03be172fc3b199c7a06433163e459be5b110a6983c1dd6305b7ac10f6b0fa12e1440755a8df6b1064ab2ccb789df0474919fb9c684e322dc57685ede21752ccb",
  "dependencies": {
    "chalk": "^4.0.0",
    "log-symbols": "7.0.1"
  },
  "devDependencies": {
    "@babel/register": "7.29.7",
    "@travi/any": "3.3.0",
    "@travi/babel-preset": "3.0.151",
    "@travi/eslint-config-travi": "1.8.8",
    "ban-sensitive-files": "1.10.11",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "commitlint-config-travi": "1.4.67",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "mocha": "11.7.6",
    "npm-run-all2": "9.0.1",
    "publint": "0.3.21",
    "remark-cli": "12.0.1",
    "remark-preset-lint-travi": "6.0.8",
    "rimraf": "6.1.3",
    "rollup": "4.61.1",
    "rollup-plugin-auto-external": "2.0.0",
    "sinon": "22.0.0"
  }
}
